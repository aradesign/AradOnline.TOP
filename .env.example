# کپی: cp .env.example .env — هرگز .env را commit نکنید.
#
# Local:  DATABASE_URL="file:./dev.db"
# VPS:    DATABASE_URL="file:../data/prod.db"
DATABASE_URL="file:./dev.db"

# مقادیر واقعی را خودتان انتخاب کنید (در گیت قرار ندهید)
ADMIN_PASSWORD="change-me-strong-password"
SESSION_SECRET="change-me-use-openssl-rand-hex-32"

PORT=3000
NODE_ENV=development
